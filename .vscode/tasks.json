{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "dotrush.task",
			"project": "${command:dotrush.activeProjectPath}",
			"problemMatcher": "$msCompile",
			"label": "dotrush: Build",
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"label": "build-debug",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"-c",
				"Debug"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "build-release",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"-c",
				"Release"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		}
	]
}
